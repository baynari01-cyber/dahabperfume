generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// AUTHENTICATION & EMPLOYEES
// ==========================================

model Employee {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  isActive     Boolean   @default(true)
  roleId       String
  role         Role      @relation(fields: [roleId], references: [id])
  sessions     Session[]
  auditLogs    AuditLog[]
  orders       Order[]   @relation("OrderConfirmedBy")
  sales        Sale[]    @relation("SaleCashier")
  movements    InventoryMovement[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., Admin, Manager, Seller
  permissions Permission[]
  employees   Employee[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(cuid())
  action    String   // e.g., "manage:products", "pos:access"
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  
  @@unique([roleId, action])
}

model Session {
  id         String   @id // The opaque session token
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  expiresAt  DateTime

  createdAt  DateTime @default(now())
}

// ==========================================
// CATALOG & PRODUCTS
// ==========================================

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum Season {
  SUMMER
  WINTER
  ALL_SEASONS
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique // e.g., رجالي, نسائي, عود, مكس
  slug     String    @unique
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                String    @id @default(cuid())
  sku               String    @unique
  slug              String    @unique
  nameAr            String
  nameEn            String?
  inspiredBy        String?   // Internal only
  
  categoryId        String
  category          Category  @relation(fields: [categoryId], references: [id])
  
  gender            Gender
  season            Season
  family            String
  
  keywords          String?
  shortDescription  String?
  adminNotes        String?
  
  lowStockThreshold Int       @default(5)
  useGlobalPricing  Boolean   @default(true)
  isVisible         Boolean   @default(true)
  isFeatured        Boolean   @default(false)
  featuredOrder     Int       @default(0)
  needsReview       Boolean   @default(false)

  variants          ProductVariant[]
  images            ProductImage[]
  accords           ProductAccord[]
  inventory         InventoryMovement[]
  formulas          ProductFormula[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([isVisible])
  @@index([categoryId])
  @@index([gender])
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size       String  // e.g., "50ml", "100ml"
  price      Int     // In minor currency (JOD piastres)
  
  orderItems OrderItem[]
  saleItems  SaleItem[]
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, size])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String  // Supabase object path
  isMain    Boolean @default(false)
  order     Int     @default(0)

  createdAt DateTime @default(now())
}

model ProductAccord {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String  // e.g. "حمضي"
  value     Float   // Strength (e.g. 95.0)
  order     Int     @default(0)

  @@index([productId])
}

// ==========================================
// TRANSACTIONS & SALES
// ==========================================

enum OrderStatus {
  AWAITING_WHATSAPP
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  EXPIRED
}

model Order {
  id              String      @id @default(cuid())
  reference       String      @unique // Secure order reference
  status          OrderStatus @default(AWAITING_WHATSAPP)
  
  customerName    String
  customerPhone   String
  customerCity    String
  customerAddress String
  notes           String?
  
  subtotal        Int         // Minor currency
  shippingFee     Int
  total           Int

  confirmedById   String?
  confirmedBy     Employee?   @relation("OrderConfirmedBy", fields: [confirmedById], references: [id])
  
  items           OrderItem[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
}

model OrderItem {
  id               String         @id @default(cuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId        String
  variant          ProductVariant @relation(fields: [variantId], references: [id])
  quantity         Int
  priceAtOrder     Int            // Immutable
  
  createdAt        DateTime       @default(now())
}

model Sale {
  id            String     @id @default(cuid())
  invoiceNumber String     @unique
  cashierId     String
  cashier       Employee   @relation("SaleCashier", fields: [cashierId], references: [id])
  
  subtotal      Int
  discount      Int        @default(0)
  total         Int
  amountPaid    Int
  change        Int
  
  paymentMethod String     // CASH, CARD, etc.
  notes         String?
  isVoided      Boolean    @default(false)
  
  items         SaleItem[]
  
  createdAt     DateTime   @default(now())
}

model SaleItem {
  id           String         @id @default(cuid())
  saleId       String
  sale         Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variantId    String
  variant      ProductVariant @relation(fields: [variantId], references: [id])
  quantity     Int
  priceAtSale  Int
  
  createdAt    DateTime       @default(now())
}

// ==========================================
// INVENTORY & FORMULAS
// ==========================================

enum MovementType {
  STOCK_IN
  MANUAL_ADJUSTMENT
  SALE_CONSUMPTION
  ORDER_CONSUMPTION
  RETURN
  WASTE
  CORRECTION
}

model InventoryMovement {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  type        MovementType
  quantity    Int          // Can be positive or negative
  reason      String?
  
  actorId     String
  actor       Employee     @relation(fields: [actorId], references: [id])
  
  createdAt   DateTime     @default(now())
  
  @@index([productId])
  @@index([type])
}

model RawMaterial {
  id            String  @id @default(cuid())
  name          String  @unique
  unit          String  // e.g., ml, g, pcs
  currentStock  Float   @default(0)
  
  formulaItems  ProductFormulaItem[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProductFormula {
  id        String               @id @default(cuid())
  productId String
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String               // e.g. "Standard 50ml Mix"
  
  items     ProductFormulaItem[]
  
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model ProductFormulaItem {
  id            String         @id @default(cuid())
  formulaId     String
  formula       ProductFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  rawMaterialId String
  rawMaterial   RawMaterial    @relation(fields: [rawMaterialId], references: [id])
  quantity      Float          // Amount required per unit of variant
  
  createdAt     DateTime       @default(now())
  
  @@unique([formulaId, rawMaterialId])
}

// ==========================================
// SYSTEM & AUDIT
// ==========================================

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     Employee? @relation(fields: [actorId], references: [id])
  action    String
  entityType String
  entityId   String
  details   String   // JSON stringified safe summary
  
  createdAt DateTime @default(now())

  @@index([action])
  @@index([entityType, entityId])
}

model Setting {
  key       String   @id
  value     String   // JSON stringified value
  updatedAt DateTime @updatedAt
}
