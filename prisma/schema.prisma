generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------
// AUTHENTICATION & AUTHORIZATION
// ----------------------------------------------------------------------

model Employee {
  id             String         @id @default(uuid())
  email          String         @unique
  name           String
  passwordHash   String         // Argon2id hash
  isActive       Boolean        @default(true)
  roleId         String
  role           Role           @relation(fields: [roleId], references: [id])
  sessions       Session[]
  loginAttempts  LoginAttempt[]
  auditLogs      AuditLog[]
  sales          Sale[]
  returns        Return[]
  inventoryMoves InventoryMovement[]
  failedAttempts Int            @default(0)
  lockoutUntil   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  employees   Employee[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  action      String           @unique // e.g., 'manage_products', 'manage_employees', 'void_sale'
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id         String   @id // SHA-256 hash of the session token
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model LoginAttempt {
  id         String   @id @default(uuid())
  email      String
  ipAddress  String?
  userAgent  String?
  success    Boolean
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

// ----------------------------------------------------------------------
// PRODUCT CATALOG
// ----------------------------------------------------------------------

model Product {
  id               String           @id @default(uuid())
  slug             String           @unique
  nameAr           String
  nameEn           String
  sku              String           @unique
  shortDescription String?
  longDescription  String?
  categoryId       String
  category         Category         @relation(fields: [categoryId], references: [id])
  collectionId     String?
  collection       Collection?      @relation(fields: [collectionId], references: [id])
  genderId         String?
  gender           Gender?          @relation(fields: [genderId], references: [id])
  seasonId         String?
  season           Season?          @relation(fields: [seasonId], references: [id])
  familyId         String?
  family           FragranceFamily? @relation(fields: [familyId], references: [id])
  isVisible        Boolean          @default(true)
  isFeatured       Boolean          @default(false)
  featuredOrder    Int              @default(0)
  needsReview      Boolean          @default(false)
  reviewReasons    String?          // e.g. "Missing Image"
  stockStatus      String           @default("UNVERIFIED")
  variants         ProductVariant[]
  images           ProductImage[]
  accords          ProductAccord[]
  notes            ProductNote[]
  orderItems       OrderItem[]
  formulas         ProductFormula[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size        String   // e.g. "50ml", "100ml"
  sku         String   @unique
  price       Int      // Stored in minor units (e.g. fils or cents)
  compareAt   Int?
  stock       Int      @default(0) // Used for FINISHED_PRODUCT mode
  isActive    Boolean  @default(true)
  saleItems   SaleItem[]
  returnItems ReturnItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  isMain    Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Category {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  description String?
  products    Product[]
}

model Collection {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  description String?
  image       String?
  products    Product[]
}

model Gender {
  id       String    @id @default(uuid())
  name     String    @unique // e.g. "رجالي", "نسائي", "للجنسين"
  products Product[]
}

model Season {
  id       String    @id @default(uuid())
  name     String    @unique // e.g. "صيفي", "شتوي"
  products Product[]
}

model FragranceFamily {
  id       String    @id @default(uuid())
  name     String    @unique // e.g. "خشبي", "زهري"
  products Product[]
}

model Accord {
  id       String          @id @default(uuid())
  name     String          @unique // e.g. "عود", "مسك"
  color    String?         // Hex code for UI representation
  products ProductAccord[]
}

model ProductAccord {
  productId String
  accordId  String
  value     Int      // 0-100 percentage or weight
  order     Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  accord    Accord   @relation(fields: [accordId], references: [id], onDelete: Cascade)

  @@id([productId, accordId])
}

model ProductNote {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String  // "TOP", "MIDDLE", "BASE"
  name      String
}

// ----------------------------------------------------------------------
// ORDERS & SALES (STOREFRONT + POS)
// ----------------------------------------------------------------------

model Order {
  id            String               @id @default(uuid())
  reference     String               @unique // Secure public reference
  customerName  String
  customerPhone String
  status        String               // "AWAITING_WHATSAPP", "CONFIRMED", "SHIPPED", "DELIVERED", "CANCELLED"
  totalAmount   Int
  shippingCost  Int
  notes         String?
  idempotencyKey String?              @unique
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  invoice       Invoice?
  paymentStatus String               @default("UNPAID") // "UNPAID", "COD_PENDING", "PARTIALLY_PAID", "PAID", "REFUNDED"
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String
  sku       String
  name      String
  size      String
  quantity  Int
  unitPrice Int
  total     Int
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  notes     String?
  createdAt DateTime @default(now())
}

model Sale {
  id            String     @id @default(uuid())
  reference     String     @unique
  employeeId    String
  employee      Employee   @relation(fields: [employeeId], references: [id])
  customerName  String?    @default("عميل نقدي")
  subtotal      Int
  tax           Int
  discount      Int        @default(0)
  total         Int
  status        String     // "COMPLETED", "VOIDED"
  source        String     @default("POS")
  items         SaleItem[]
  payments      Payment[]
  invoice       Invoice?
  returns       Return[]
  createdAt     DateTime   @default(now())
}

model SaleItem {
  id         String         @id @default(uuid())
  saleId     String
  sale       Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  sku        String
  name       String
  size       String
  quantity   Int
  unitPrice  Int
  total      Int
}

model Payment {
  id            String   @id @default(uuid())
  saleId        String
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method        String   // "CASH", "CARD"
  amount        Int      // The applied payment amount
  amountTendered Int?    // The physical amount tendered by the customer
  terminalRef   String?  // Cashier-recorded card terminal reference
  createdAt     DateTime @default(now())
}

model Invoice {
  id                      String   @id @default(uuid())
  saleId                  String?  @unique
  sale                    Sale?    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  orderId                 String?  @unique
  order                   Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  number                  String   @unique // Sequential invoice number
  taxId                   String?  // Company Tax ID at time of sale
  
  // Unambiguous Financial Snapshots (in Fils)
  netSubtotalFils         Int      @default(0)
  discountAmountFils      Int      @default(0)
  shippingAmountFils      Int      @default(0)
  taxAmountFils           Int      @default(0)
  grossTotalFils          Int      @default(0)
  taxRateSnapshot         Float    @default(0.0)
  taxModeSnapshot         String   @default("DISABLED") // "DISABLED", "INCLUSIVE", "EXCLUSIVE"
  pricesIncludeTaxSnapshot Boolean @default(true)
  
  // Payment & Cash Tender/Allocation Breakdown (in Fils)
  cashAppliedFils         Int      @default(0)
  cardAppliedFils         Int      @default(0)
  cashTenderedFils        Int      @default(0)
  changeDueFils           Int      @default(0)
  paymentStatus           String   @default("UNPAID") // "UNPAID", "COD_PENDING", "PARTIALLY_PAID", "PAID", "REFUNDED", "PARTIALLY_REFUNDED"
  confirmedByEmployeeId   String?  // Employee who confirmed storefront order or processed POS sale
  
  printed                 Int      @default(0) // Number of times printed
  createdAt               DateTime @default(now())
}

model Return {
  id         String       @id @default(uuid())
  saleId     String
  sale       Sale         @relation(fields: [saleId], references: [id])
  employeeId String
  employee   Employee     @relation(fields: [employeeId], references: [id])
  reason     String?
  totalAmount Int
  items      ReturnItem[]
  createdAt  DateTime     @default(now())
}

model ReturnItem {
  id        String         @id @default(uuid())
  returnId  String
  return    Return         @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  amount    Int
}

// ----------------------------------------------------------------------
// INVENTORY & FORMULAS
// ----------------------------------------------------------------------

model RawMaterialCategory {
  id        String        @id @default(uuid())
  name      String        @unique // e.g. "زيوت عطرية", "كحول", "زجاجات", "علب"
  materials RawMaterial[]
}

model RawMaterial {
  id            String               @id @default(uuid())
  sku           String               @unique
  name          String
  categoryId    String
  category      RawMaterialCategory  @relation(fields: [categoryId], references: [id])
  unit          String               // e.g. "ml", "g", "pcs"
  costPerUnit   Int                  // Stored in minor units
  stock         RawMaterialStock?
  movements     RawMaterialMovement[]
  formulaItems  ProductFormulaItem[]
  consumptions  ConsumptionRecord[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model RawMaterialStock {
  id            String      @id @default(uuid())
  materialId    String      @unique
  material      RawMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  quantity      Float       // Using Float/Decimal for ml/g measurements
  minThreshold  Float?
  lastUpdated   DateTime    @updatedAt
}

model RawMaterialMovement {
  id         String      @id @default(uuid())
  materialId String
  material   RawMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  type       String      // "IN", "OUT", "ADJUSTMENT", "CONSUMPTION"
  quantity   Float
  reference  String?     // e.g. PO number or Sale ID
  notes      String?
  createdAt  DateTime    @default(now())
}

model ProductFormula {
  id        String               @id @default(uuid())
  productId String
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String               // e.g. "تركيبة عود الروح 50 مل"
  size      String               // Maps to variant size
  isActive  Boolean              @default(true)
  items     ProductFormulaItem[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model ProductFormulaItem {
  id         String         @id @default(uuid())
  formulaId  String
  formula    ProductFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  materialId String
  material   RawMaterial    @relation(fields: [materialId], references: [id])
  quantity   Float          // Amount required per unit
}

model ConsumptionRecord {
  id         String      @id @default(uuid())
  materialId String
  material   RawMaterial @relation(fields: [materialId], references: [id])
  quantity   Float
  saleId     String?     // Link to the POS sale that triggered this
  createdAt  DateTime    @default(now())
}

model InventoryMovement {
  id         String   @id @default(uuid())
  sku        String
  type       String   // "IN", "OUT", "SALE", "RETURN"
  quantity   Int
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  reference  String?
  createdAt  DateTime @default(now())
}

model StockAdjustment {
  id        String   @id @default(uuid())
  sku       String
  oldStock  Int
  newStock  Int
  reason    String
  createdAt DateTime @default(now())
}

// ----------------------------------------------------------------------
// SYSTEM & CMS
// ----------------------------------------------------------------------

model AuditLog {
  id         String    @id @default(uuid())
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  action     String    // e.g. "SALE_VOIDED", "PRODUCT_UPDATED"
  entityType String
  entityId   String
  details    String?   // JSON string with changes
  ipAddress  String?
  createdAt  DateTime  @default(now())
}

model SiteSettings {
  key   String @id
  value String // JSON string
}

model GlobalPricingSettings {
  id               String  @id @default("1")
  taxEnabled       Boolean @default(false)
  taxRate          Float   @default(0.0)
  pricesIncludeTax Boolean @default(true)
  currencyCode     String  @default("JOD")
  currencySymbol   String  @default("د.أ")
}

model ShippingZone {
  id                    String   @id @default(uuid())
  nameAr                String
  nameEn                String
  fee                   Int      // in minor units (fils)
  estimatedDeliveryTime String   // e.g. "24-48 hours"
  isEnabled             Boolean  @default(true)
  freeShippingThreshold Int?     // in minor units, null means disabled
}

